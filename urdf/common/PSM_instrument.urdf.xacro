<?xml version="1.0" encoding="utf-8"?>
<robot name="dvrk_psm_instrument" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!--
    PSM instrument macro — generation-agnostic.

    Attaches to ${parent_link} (= ${prefix}PSM_tool_parent_link from any
    PSM_base variant: Classic, Si, or Virtual).

    DOF layout:
      Joint 4: roll         (revolute, D = shaft_length along z)
      Joint 5: wrist_pitch  (revolute)  ┐
      Joint 6: wrist_yaw    (revolute)  ├── dispatched via PSM_tip_XXX macro
      Joint 7: jaw + mimics (revolute)  ┘

    Parameters:
      prefix        — arm instance prefix, e.g. "PSM1_"
      parent_link   — must be ${prefix}PSM_tool_parent_link
      shaft_length  — D parameter of roll joint (Classic: 0.4162, Si: 0.4670)
      tool_model    — last 6 digits of instrument model number (e.g. "420006")
                      used to select the correct PSM_tip_XXX macro
  -->

  <xacro:include filename="$(find dvrk_model)/urdf/common.urdf.xacro"/>
  <xacro:include filename="$(find dvrk_model)/urdf/common/PSM_tips.urdf.xacro"/>

  <xacro:macro name="PSM_instrument"
               params="prefix parent_link tool_model">
               
    <!-- Detect if this is an Si generation instrument (42xxxx) -->
    <xacro:property name="is_si" value="${str(tool_model).startswith('42')}"/>
    
    <!-- Dynamically select the correct shaft length based on generation -->
    <xacro:property name="shaft_length" value="${0.53559 if is_si else 0.4162}"/>

    <!-- fixed joint to hold the shaft visual BEFORE the roll joint -->
    <joint name="instrument_base_fixed" type="fixed">
      <parent link="${parent_link}"/>
      <child  link="${prefix}PSM_instrument_base_link"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </joint>

    <link name="${prefix}PSM_instrument_base_link">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <xacro:if value="${is_si}">
            <mesh filename="package://dvrk_model/meshes/instruments/420006/tool_main_link.STL"/>
          </xacro:if>
          <xacro:unless value="${is_si}">
            <mesh filename="package://dvrk_model/meshes/Classic/PSM/PSM_tool_main.dae"/>
          </xacro:unless>
        </geometry>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <xacro:if value="${is_si}">
            <mesh filename="package://dvrk_model/meshes/instruments/420006/tool_main_link.STL"/>
          </xacro:if>
          <xacro:unless value="${is_si}">
            <mesh filename="package://dvrk_model/meshes/Classic/PSM/PSM_tool_main.dae"/>
          </xacro:unless>
        </geometry>
      </collision>
    </link>

    <!-- joint 4: roll (outer roll of instrument inner shaft) -->
    <joint name="roll" type="revolute">
      <parent link="${parent_link}"/>
      <child  link="${prefix}PSM_roll_link"/>
      <axis xyz="0 0 1"/>
      <origin rpy="0 0 0" xyz="0 0 ${shaft_length}"/>
      <limit lower="-4.53786" upper="4.53786" velocity=".4" effort="1000"/>
    </joint>

    <!--
      PSM_roll_link — carries the inner shaft rotation.
      The outer shaft mesh (above) does not roll or shift.
    -->
    <link name="${prefix}PSM_roll_link"/>

    <!-- fixed joint to wrist body -->
    <joint name="roll_fixed" type="fixed">
      <parent link="${prefix}PSM_roll_link"/>
      <child  link="${prefix}PSM_wrist_link"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </joint>

    <link name="${prefix}PSM_wrist_link">
      <visual>
        <xacro:if value="${is_si}">
          <!-- Si roll wrist piece is centered at the roll joint -->
          <origin rpy="-${PI} 0 0" xyz="0.05591 0 0"/>
          <geometry>
            <mesh filename="package://dvrk_model/meshes/instruments/420006/tool_wrist_link.STL"/>
          </geometry>
          <material name=""><color rgba="0.79216 0.81961 0.93333 1"/></material>
        </xacro:if>
        <xacro:unless value="${is_si}">
          <!-- Classic shaft spins with the wrist -->
          <origin rpy="0 0 0" xyz="0 0 -${shaft_length}"/>
          <geometry>
            <mesh filename="package://dvrk_model/meshes/Classic/PSM/PSM_shaft.dae"/>
          </geometry>
        </xacro:unless>
      </visual>
      <collision>
        <xacro:if value="${is_si}">
          <origin rpy="-${PI} 0 0" xyz="0.05591 0 0"/>
          <geometry>
            <mesh filename="package://dvrk_model/meshes/instruments/420006/tool_wrist_link.STL"/>
          </geometry>
        </xacro:if>
        <xacro:unless value="${is_si}">
          <origin rpy="0 0 0" xyz="0 0 -${shaft_length}"/>
          <geometry>
            <mesh filename="package://dvrk_model/meshes/Classic/PSM/PSM_shaft.dae"/>
          </geometry>
        </xacro:unless>
      </collision>
    </link>

    <!-- fixed joint to wrist shaft -->
    <joint name="wrist_shaft_fixed" type="fixed">
      <parent link="${prefix}PSM_wrist_link"/>
      <child  link="${prefix}PSM_wrist_shaft_link"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </joint>

    <link name="${prefix}PSM_wrist_shaft_link">
      <visual>
        <xacro:if value="${is_si}">
          <origin rpy="0 0 0" xyz="0 0 0"/>
          <geometry>
            <mesh filename="package://dvrk_model/meshes/instruments/420006/tool_wrist_shaft_link.STL"/>
          </geometry>
          <material name=""><color rgba="0.79216 0.81961 0.93333 1"/></material>
        </xacro:if>
        <xacro:unless value="${is_si}">
          <origin rpy="${PI_2} 0 0" xyz="0 0.00401 0"/>
          <geometry>
            <mesh filename="package://dvrk_model/meshes/Classic/PSM/PSM_wrist_shaft.dae"/>
          </geometry>
        </xacro:unless>
      </visual>
      <collision>
        <xacro:if value="${is_si}">
          <origin rpy="0 0 0" xyz="0 0 0"/>
          <geometry>
            <mesh filename="package://dvrk_model/meshes/instruments/420006/tool_wrist_shaft_link.STL"/>
          </geometry>
        </xacro:if>
        <xacro:unless value="${is_si}">
          <origin rpy="${PI_2} 0 0" xyz="0 0.00401 0"/>
          <geometry>
            <mesh filename="package://dvrk_model/meshes/Classic/PSM/PSM_wrist_shaft.dae"/>
          </geometry>
        </xacro:unless>
      </collision>
    </link>

    <!--
      Tip dispatch: select the correct wrist+jaw macro by tool_model.
      Convention: last 3 digits of the model number identify the tip family.
        006 → standard SCA wrist (most instruments, A=0.0091)
        049 → Cadiere jaw (same wrist, different jaw geometry)
        172 → Maryland wrist (A=0.0107)
        117 → snake tool (5 mm shaft, extra coupled joints)
        183 → cautery / no-jaw tools
    -->
    <xacro:if value="${str(tool_model) == '420006' or str(tool_model) == '400006' or
                      str(tool_model) == '420036' or str(tool_model) == '400036' or
                      str(tool_model) == '420093' or str(tool_model) == '400093' or
                      str(tool_model) == '420168' or str(tool_model) == '400168'}">
      <xacro:PSM_tip_006 prefix="${prefix}"
                         parent_link="${prefix}PSM_wrist_shaft_link"/>
    </xacro:if>

    <xacro:if value="${str(tool_model) == '420049' or str(tool_model) == '400049'}">
      <xacro:PSM_tip_049 prefix="${prefix}"
                         parent_link="${prefix}PSM_wrist_shaft_link"/>
    </xacro:if>

    <xacro:if value="${str(tool_model) == '420172' or str(tool_model) == '400172'}">
      <xacro:PSM_tip_172 prefix="${prefix}"
                         parent_link="${prefix}PSM_wrist_shaft_link"/>
    </xacro:if>

    <xacro:if value="${str(tool_model) == '400117'}">
      <xacro:PSM_tip_117 prefix="${prefix}"
                         parent_link="${prefix}PSM_wrist_shaft_link"/>
    </xacro:if>

    <xacro:if value="${str(tool_model) == 'SF0826001'}">
      <xacro:PSM_tip_ECM prefix="${prefix}"
                         parent_link="${prefix}PSM_wrist_shaft_link"/>
    </xacro:if>

  </xacro:macro>

</robot>
