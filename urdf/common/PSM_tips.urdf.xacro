<?xml version="1.0" encoding="utf-8"?>
<robot name="dvrk_psm_tips" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!--
    PSM tip family macros — generation-agnostic.

    All macros attach to ${parent_link} (= ${prefix}PSM_wrist_shaft_link).
    Tip families are identified by the last 3 digits of the instrument model:

      PSM_tip_006  — standard SCA wrist  (A=0.0091 m, most instruments)
      PSM_tip_049  — Cadiere jaw         (same wrist as 006, different jaw)
      PSM_tip_172  — Maryland wrist      (A=0.0107 m)
      PSM_tip_117  — snake / needle driver 5 mm (extra coupled wrist joints)
      PSM_tip_183  — cautery / no-jaw tools
      PSM_tip_ECM  — ECM camera tip
  -->

  <xacro:include filename="$(find dvrk_model)/urdf/common.urdf.xacro"/>

  <!-- ════════════════════════════════════════════════════════════════════ -->
  <!-- PSM_tip_006 — standard SCA wrist (most Classic and Si instruments)  -->
  <!-- ════════════════════════════════════════════════════════════════════ -->
  <xacro:macro name="PSM_tip_006" params="prefix parent_link">

    <!-- joint 5: wrist_pitch -->
    <joint name="wrist_pitch" type="revolute">
      <parent link="${parent_link}"/>
      <child  link="${prefix}PSM_tip_006_wrist_link"/>
      <axis xyz="0 0 1"/>
      <origin rpy="-${PI_2} -${PI_2} 0" xyz="0 0 0"/>
      <limit lower="-${PI_2}" upper="${PI_2}" velocity=".4" effort="1000"/>
    </joint>

    <link name="${prefix}PSM_tip_006_wrist_link">
      <visual>
        <origin rpy="${PI_2} ${PI} 0" xyz="0.0051 0.0032 0"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Classic/PSM/PSM_tip_006_wrist.dae"/>
        </geometry>
      </visual>
    </link>

    <!-- joint 6: wrist_yaw -->
    <joint name="wrist_yaw" type="revolute">
      <parent link="${prefix}PSM_tip_006_wrist_link"/>
      <child  link="${prefix}PSM_tip_006_shaft_link"/>
      <axis xyz="0 0 1"/>
      <origin rpy="-${PI_2} -${PI_2} 0" xyz="0.0091 0 0"/>
      <limit lower="-1.3963" upper="1.3963" velocity=".4" effort="1000"/>
    </joint>

    <link name="${prefix}PSM_tip_006_shaft_link">
      <visual>
        <origin rpy="0 0 0" xyz="0 -0.0002 -0.0025"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Classic/PSM/PSM_tip_006_shaft.dae"/>
        </geometry>
      </visual>
    </link>

    <!-- joint 7-0: jaw (virtual centre — drives the mimics) -->
    <joint name="jaw" type="revolute">
      <parent link="${prefix}PSM_tip_006_shaft_link"/>
      <child  link="${prefix}PSM_jaw_link"/>
      <axis xyz="0 0 1"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <limit lower="0" upper="${PI_2}" velocity=".4" effort="1000"/>
    </joint>

    <!-- virtual jaw link (zero-size, drives mimics) -->
    <link name="${prefix}PSM_jaw_link">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry><box size="0 0 0"/></geometry>
      </visual>
    </link>

    <!-- jaw mimic 1 — opens +0.5× -->
    <joint name="jaw_1" type="revolute">
      <parent link="${prefix}PSM_tip_006_shaft_link"/>
      <child  link="${prefix}PSM_jaw_1_link"/>
      <axis xyz="0 0 1"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <limit lower="-1.5707" upper="1.5707" velocity=".4" effort="1000"/>
      <mimic joint="jaw" multiplier="0.5"/>
    </joint>

    <link name="${prefix}PSM_jaw_1_link">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Classic/PSM/PSM_tip_006_jaw.dae"/>
        </geometry>
      </visual>
    </link>

    <!-- jaw mimic 2 — opens −0.5× (symmetric) -->
    <joint name="jaw_2" type="revolute">
      <parent link="${prefix}PSM_tip_006_shaft_link"/>
      <child  link="${prefix}PSM_jaw_2_link"/>
      <axis xyz="0 0 1"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <limit lower="-1.5707" upper="1.5707" velocity=".4" effort="1000"/>
      <mimic joint="jaw" multiplier="-0.5"/>
    </joint>

    <link name="${prefix}PSM_jaw_2_link">
      <visual>
        <origin rpy="0 ${PI} 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Classic/PSM/PSM_tip_006_jaw.dae"/>
        </geometry>
      </visual>
    </link>

    <!-- tool tip reference frame -->
    <joint name="tool_tip" type="fixed">
      <parent link="${prefix}PSM_tip_006_shaft_link"/>
      <child  link="${prefix}PSM_tool_tip_link"/>
      <origin rpy="0 ${pi/2} ${pi/2}" xyz="0 0.0102 0"/>
    </joint>
    <link name="${prefix}PSM_tool_tip_link"/>

  </xacro:macro>


  <!-- ════════════════════════════════════════════════════════════════════ -->
  <!-- PSM_tip_049 — Cadiere jaw (same wrist geometry as 006)              -->
  <!-- ════════════════════════════════════════════════════════════════════ -->
  <xacro:macro name="PSM_tip_049" params="prefix parent_link">

    <joint name="wrist_pitch" type="revolute">
      <parent link="${parent_link}"/>
      <child  link="${prefix}PSM_tip_049_wrist_link"/>
      <axis xyz="0 0 1"/>
      <origin rpy="-${PI_2} -${PI_2} 0" xyz="0 0 0"/>
      <limit lower="-${PI_2}" upper="${PI_2}" velocity=".4" effort="1000"/>
    </joint>

    <link name="${prefix}PSM_tip_049_wrist_link">
      <visual>
        <origin rpy="0 -${PI_2} 0" xyz="-0.0024 0 0"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Classic/PSM/PSM_tip_049_wrist.stl"/>
        </geometry>
      </visual>
    </link>

    <joint name="wrist_yaw" type="revolute">
      <parent link="${prefix}PSM_tip_049_wrist_link"/>
      <child  link="${prefix}PSM_tip_049_shaft_link"/>
      <axis xyz="0 0 1"/>
      <origin rpy="0 -${PI_2} -${PI_2}" xyz="0.0091 0 0"/>
      <limit lower="-1.3963" upper="1.3963" velocity=".4" effort="1000"/>
    </joint>

    <link name="${prefix}PSM_tip_049_shaft_link">
      <visual>
        <origin rpy="0 ${PI_2} 0" xyz="0 -0.0002 0"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Classic/PSM/PSM_tip_049_shaft.stl"/>
        </geometry>
      </visual>
    </link>

    <joint name="jaw" type="revolute">
      <parent link="${prefix}PSM_tip_049_shaft_link"/>
      <child link="${prefix}PSM_jaw_link"/>
      <axis xyz="0 0 1"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <limit lower="-0.349066" upper="1.5708" velocity=".4" effort="1000"/>
    </joint>

    <link name="${prefix}PSM_jaw_link">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry><box size="0 0 0"/></geometry>
      </visual>
    </link>

    <joint name="jaw_1" type="revolute">
      <parent link="${prefix}PSM_tip_049_shaft_link"/>
      <child link="${prefix}PSM_jaw_1_link"/>
      <axis xyz="0 0 1"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <limit lower="-0.349066" upper="1.5708" velocity=".4" effort="1000"/>
      <mimic joint="jaw" multiplier="0.5"/>
    </joint>

    <link name="${prefix}PSM_jaw_1_link">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0.00195"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Classic/PSM/PSM_tip_049_jaw.stl"/>
        </geometry>
      </visual>
    </link>

    <joint name="jaw_2" type="revolute">
      <parent link="${prefix}PSM_tip_049_shaft_link"/>
      <child link="${prefix}PSM_jaw_2_link"/>
      <axis xyz="0 0 1"/>
      <origin rpy="${PI} 0 0" xyz="0 0 0"/>
      <limit lower="-0.349066" upper="1.5708" velocity=".4" effort="1000"/>
      <mimic joint="jaw" multiplier="0.5"/>
    </joint>

    <link name="${prefix}PSM_jaw_2_link">
      <visual>
        <origin rpy="0 0 -${PI}" xyz="0 0 0.00195"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Classic/PSM/PSM_tip_049_jaw.stl"/>
        </geometry>
      </visual>
    </link>

    <joint name="tool_tip" type="fixed">
      <parent link="${prefix}PSM_tip_049_shaft_link"/>
      <child link="${prefix}PSM_tool_tip_link"/>
      <origin rpy="0 ${PI_2} ${PI_2}" xyz="0 0 0"/>
    </joint>
    <link name="${prefix}PSM_tool_tip_link"/>

  </xacro:macro>


  <!-- ════════════════════════════════════════════════════════════════════ -->
  <!-- PSM_tip_172 — Maryland wrist (A=0.0107 m)                          -->
  <!-- ════════════════════════════════════════════════════════════════════ -->
  <xacro:macro name="PSM_tip_172" params="prefix parent_link">

    <!-- joint 5: wrist_pitch -->
    <joint name="wrist_pitch" type="revolute">
      <parent link="${parent_link}"/>
      <child  link="${prefix}PSM_tip_172_wrist_link"/>
      <axis xyz="0 0 1"/>
      <origin rpy="-${PI_2} -${PI_2} 0" xyz="0 0 0"/>
      <limit lower="-${PI_2}" upper="${PI_2}" velocity=".4" effort="1000"/>
    </joint>

    <!--
      NOTE: Maryland wrist mesh — use PSM_tip_006_wrist.dae as placeholder
      until a dedicated Maryland wrist mesh is added to the repo.
    -->
    <link name="${prefix}PSM_tip_172_wrist_link">
      <visual>
        <origin rpy="${PI_2} ${PI} 0" xyz="0.0051 0.0032 0"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Classic/PSM/PSM_tip_006_wrist.dae"/>
        </geometry>
      </visual>
    </link>

    <!-- joint 6: wrist_yaw (A=0.0107 — Maryland specific) -->
    <joint name="wrist_yaw" type="revolute">
      <parent link="${prefix}PSM_tip_172_wrist_link"/>
      <child  link="${prefix}PSM_tip_172_shaft_link"/>
      <axis xyz="0 0 1"/>
      <origin rpy="-${PI_2} -${PI_2} 0" xyz="0.0107 0 0"/>
      <limit lower="-1.3963" upper="1.3963" velocity=".4" effort="1000"/>
    </joint>

    <link name="${prefix}PSM_tip_172_shaft_link">
      <visual>
        <origin rpy="0 0 0" xyz="0 -0.0002 -0.0025"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Classic/PSM/PSM_tip_006_shaft.dae"/>
        </geometry>
      </visual>
    </link>

    <!-- jaw + symmetric mimics (same as tip_006) -->
    <joint name="jaw" type="revolute">
      <parent link="${prefix}PSM_tip_172_shaft_link"/>
      <child  link="${prefix}PSM_jaw_link"/>
      <axis xyz="0 0 1"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <limit lower="0" upper="${PI_2}" velocity=".4" effort="1000"/>
    </joint>

    <link name="${prefix}PSM_jaw_link">
      <visual><origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry><box size="0 0 0"/></geometry>
      </visual>
    </link>

    <joint name="jaw_1" type="revolute">
      <parent link="${prefix}PSM_tip_172_shaft_link"/>
      <child  link="${prefix}PSM_jaw_1_link"/>
      <axis xyz="0 0 1"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <limit lower="-1.5707" upper="1.5707" velocity=".4" effort="1000"/>
      <mimic joint="jaw" multiplier="0.5"/>
    </joint>

    <link name="${prefix}PSM_jaw_1_link">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Classic/PSM/PSM_tip_006_jaw.dae"/>
        </geometry>
      </visual>
    </link>

    <joint name="jaw_2" type="revolute">
      <parent link="${prefix}PSM_tip_172_shaft_link"/>
      <child  link="${prefix}PSM_jaw_2_link"/>
      <axis xyz="0 0 1"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <limit lower="-1.5707" upper="1.5707" velocity=".4" effort="1000"/>
      <mimic joint="jaw" multiplier="-0.5"/>
    </joint>

    <link name="${prefix}PSM_jaw_2_link">
      <visual>
        <origin rpy="0 ${PI} 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Classic/PSM/PSM_tip_006_jaw.dae"/>
        </geometry>
      </visual>
    </link>

    <joint name="tool_tip" type="fixed">
      <parent link="${prefix}PSM_tip_172_shaft_link"/>
      <child  link="${prefix}PSM_tool_tip_link"/>
      <origin rpy="0 ${pi/2} ${pi/2}" xyz="0 0.0107 0"/>
    </joint>
    <link name="${prefix}PSM_tool_tip_link"/>

  </xacro:macro>


  <!-- ════════════════════════════════════════════════════════════════════ -->
  <!-- PSM_tip_117 — snake / needle driver 5 mm                            -->
  <!-- 5 mm shaft, extra coupled wrist joints (stub — meshes TBD)          -->
  <!-- ════════════════════════════════════════════════════════════════════ -->
  <xacro:macro name="PSM_tip_117" params="prefix parent_link">

    <!--
      TODO: snake tool wrist and jaw joints.
      The 5 mm snake tool has additional coupled wrist DOFs that must be
      modelled once the DH parameters and meshes are confirmed.
      Placeholder: minimal kinematic stub so the URDF parses.
    -->
    <joint name="wrist_pitch" type="revolute">
      <parent link="${parent_link}"/>
      <child  link="${prefix}PSM_tip_117_wrist_link"/>
      <axis xyz="0 0 1"/>
      <origin rpy="-${PI_2} -${PI_2} 0" xyz="0 0 0"/>
      <limit lower="-${PI_2}" upper="${PI_2}" velocity=".4" effort="1000"/>
    </joint>

    <link name="${prefix}PSM_tip_117_wrist_link"/>

    <joint name="jaw" type="revolute">
      <parent link="${prefix}PSM_tip_117_wrist_link"/>
      <child  link="${prefix}PSM_jaw_link"/>
      <axis xyz="0 0 1"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <limit lower="0" upper="${PI_2}" velocity=".4" effort="1000"/>
    </joint>

    <link name="${prefix}PSM_jaw_link"/>

    <joint name="tool_tip" type="fixed">
      <parent link="${prefix}PSM_tip_117_wrist_link"/>
      <child  link="${prefix}PSM_tool_tip_link"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </joint>
    <link name="${prefix}PSM_tool_tip_link"/>

  </xacro:macro>

  <!-- ════════════════════════════════════════════════════════════════════ -->
  <!-- PSM_tip_183 — Cautery hook (stub)                                   -->
  <!-- ════════════════════════════════════════════════════════════════════ -->
  <xacro:macro name="PSM_tip_183" params="prefix parent_link">
    <!-- Cautery tool has no jaw, just a fixed tip at the end of the shaft -->
    <joint name="tool_tip" type="fixed">
      <parent link="${parent_link}"/>
      <child  link="${prefix}PSM_tool_tip_link"/>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </joint>
    <link name="${prefix}PSM_tool_tip_link"/>
  </xacro:macro>

  <!-- ════════════════════════════════════════════════════════════════════ -->
  <!-- PSM_tip_ECM — Si ECM Camera Tip                                     -->
  <!-- ════════════════════════════════════════════════════════════════════ -->
  <xacro:macro name="PSM_tip_ECM" params="prefix parent_link">

    <joint name="wrist_pitch" type="revolute">
      <parent link="${parent_link}"/>
      <child  link="${prefix}ECM_tip_roll_link"/>
      <axis xyz="0 0 1"/>
      <origin rpy="-1.5708 -1.5708 0" xyz="0 0 0"/>
      <limit lower="-1.5707" upper="1.5707" velocity=".4" effort="1000"/>
    </joint>

    <link name="${prefix}ECM_tip_roll_link">
      <visual>
        <origin rpy="0 -${PI_2} 0" xyz="0.0051 0.0032 0"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/instruments/SF0826001/ECM_tip_roll.stl"/>
        </geometry>
      </visual>
    </link>

    <joint name="tool_tip" type="fixed">
      <parent link="${prefix}ECM_tip_roll_link"/>
      <child  link="${prefix}PSM_tool_tip_link"/>
      <origin rpy="0 0 0" xyz="0 0.0102 0"/>
    </joint>
    <link name="${prefix}PSM_tool_tip_link"/>

  </xacro:macro>

</robot>
