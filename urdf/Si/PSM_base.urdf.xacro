<?xml version="1.0" encoding="utf-8"?>
<robot name="dvrk_psm_si" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="$(find dvrk_model)/urdf/common.urdf.xacro"/>

  <!--
    Si PSM arm — 3 actuated DOF:
      Joint 1: yaw    (revolute, outer yaw)
      Joint 2: pitch  (revolute, outer pitch, parallelogram linkage ×3)
      Joint 3: insertion (prismatic)

    Macro output: ends at ${prefix}PSM_tool_parent_link.
    PSM_instrument attaches here and owns roll onward.

    Inertial data retained from original Si CAD export.
  -->

  <xacro:macro name="PSM_base"
               params="prefix parent_link
                       xyz:='0.0 0.0 0.0'
                       rpy:='0.0 0.0 0.0'">

    <!-- link 0: arm base -->
    <link name="${prefix}PSM_ECM_base_link">
      <inertial>
        <origin xyz="-0.080771 2.1131E-08 1.8613E-07" rpy="0 0 0"/>
        <mass value="1.5188"/>
        <inertia ixx="0.002395"  ixy="-2.6476E-18" ixz="-1.3484E-18"
                                  iyy="0.0040794"   iyz="4.2598E-10"
                                                     izz="0.0043778"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Si/PSM_ECM/PSM_ECM_base.stl"/>
        </geometry>
        <material name=""><color rgba="0.79216 0.81961 0.93333 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Si/PSM_ECM/PSM_ECM_base.stl"/>
        </geometry>
      </collision>
    </link>

    <!-- fixed joint: world → base -->
    <joint name="${prefix}base_fixed" type="fixed">
      <parent link="${parent_link}"/>
      <child  link="${prefix}PSM_ECM_base_link"/>
      <origin rpy="${rpy}" xyz="${xyz}"/>
    </joint>

    <!-- link 1: outer_yaw body -->
    <link name="${prefix}PSM_ECM_outer_yaw_link">
      <inertial>
        <origin xyz="0.1461 0.090363 -0.024957" rpy="0 0 0"/>
        <mass value="1.7571"/>
        <inertia ixx="0.0049404" ixy="-0.0035267" ixz="0.0045945"
                                  iyy="0.019686"   iyz="0.00070407"
                                                    izz="0.020795"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Si/PSM_ECM/PSM_ECM_outer_yaw.stl"/>
        </geometry>
        <material name=""><color rgba="0.79216 0.81961 0.93333 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Si/PSM_ECM/PSM_ECM_outer_yaw.stl"/>
        </geometry>
      </collision>
    </link>

    <!-- joint 1: yaw (outer yaw) -->
    <joint name="yaw" type="revolute">
      <origin xyz="0.158 0 0" rpy="0.0 0.0 0.0"/>
      <parent link="${prefix}PSM_ECM_base_link"/>
      <child  link="${prefix}PSM_ECM_outer_yaw_link"/>
      <axis xyz="-1.0 0.0 0.0"/>
      <limit lower="-3.14" upper="3.14" effort="0.0" velocity="0.0"/>
    </joint>

    <!-- link 2: outer pitch arm -->
    <link name="${prefix}PSM_ECM_outer_pitch_link">
      <inertial>
        <origin xyz="0.083895 -0.00073113 -0.028998" rpy="0.0 0.0 0.0"/>
        <mass value="4.017"/>
        <inertia ixx="0.012797"  ixy="-0.0002464"  ixz="0.0011164"
                                  iyy="0.026307"    iyz="8.5164E-05"
                                                     izz="0.025616"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Si/PSM_ECM/PSM_ECM_outer_pitch.stl"/>
        </geometry>
        <material name=""><color rgba="0.79216 0.81961 0.93333 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Si/PSM_ECM/PSM_ECM_outer_pitch.stl"/>
        </geometry>
      </collision>
    </link>

    <!-- joint 2: pitch (outer pitch) -->
    <joint name="pitch" type="revolute">
      <origin xyz="0.2987 0 -0.071222" rpy="0 -1.1345 -3.1416"/>
      <parent link="${prefix}PSM_ECM_outer_yaw_link"/>
      <child  link="${prefix}PSM_ECM_outer_pitch_link"/>
      <axis xyz="0 -1 0"/>
      <limit lower="-3.14" upper="3.14" effort="0" velocity="0"/>
    </joint>

    <!-- link 3: pitch parallelogram arm (mimic pitch) -->
    <link name="${prefix}PSM_ECM_outer_pitch_bottom_link">
      <inertial>
        <origin xyz="0.11824 1.9336E-19 0.12932" rpy="0 0 0"/>
        <mass value="2.1982"/>
        <inertia ixx="0.0076428"  ixy="-2.8207E-19" ixz="-0.0074855"
                                   iyy="0.032839"    iyz="-1.4256E-19"
                                                      izz="0.026585"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Si/PSM_ECM/PSM_ECM_outer_pitch_bottom.stl"/>
        </geometry>
        <material name=""><color rgba="0.79216 0.81961 0.93333 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Si/PSM_ECM/PSM_ECM_outer_pitch_bottom.stl"/>
        </geometry>
      </collision>
    </link>

    <joint name="pitch_2" type="revolute">
      <origin xyz="0.2032 0 0" rpy="0 -0.90761 -3.1416"/>
      <parent link="${prefix}PSM_ECM_outer_pitch_link"/>
      <child  link="${prefix}PSM_ECM_outer_pitch_bottom_link"/>
      <axis xyz="0 1 0"/>
      <limit lower="-3.14" upper="3.14" effort="0" velocity="0"/>
      <mimic joint="pitch" multiplier="-1"/>
    </joint>

    <!-- link 4: pitch parallelogram distal (mimic pitch) -->
    <link name="${prefix}PSM_ECM_outer_pitch_top_link">
      <inertial>
        <origin xyz="0.041219 -9.0734E-08 0.13651" rpy="0 0 0"/>
        <mass value="0.75206"/>
        <inertia ixx="0.018546"   ixy="3.3933E-09"  ixz="0.00048607"
                                   iyy="0.018573"    iyz="-1.7077E-08"
                                                      izz="0.00039277"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Si/PSM_ECM/PSM_ECM_outer_pitch_top.stl"/>
        </geometry>
        <material name=""><color rgba="0.79216 0.81961 0.93333 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://dvrk_model/meshes/Si/PSM_ECM/PSM_ECM_outer_pitch_top.stl"/>
        </geometry>
      </collision>
    </link>

    <joint name="pitch_3" type="revolute">
      <origin xyz="0.35966 0 0.16013" rpy="0 -0.063963 0"/>
      <parent link="${prefix}PSM_ECM_outer_pitch_bottom_link"/>
      <child  link="${prefix}PSM_ECM_outer_pitch_top_link"/>
      <axis xyz="0 1 0"/>
      <limit lower="-3.14" upper="3.14" effort="0" velocity="0"/>
      <mimic joint="pitch" multiplier="1"/>
    </joint>

    <!--
      joint 3: insertion (prismatic) — moved here from psm_tool.
      Origin from original outer_insertion_ref fixed joint (xyz 0.05061 0 0.41911)
      combined with the insertion joint offset.
    -->
    <joint name="insertion" type="prismatic">
      <origin xyz="0.05061 0 0.41911" rpy="${PI} 0 0"/>
      <parent link="${prefix}PSM_ECM_outer_pitch_top_link"/>
      <child  link="${prefix}PSM_tool_parent_link"/>
      <axis xyz="0 0 1"/>
      <limit lower="0.0" upper="0.299" velocity="0.4" effort="1000"/>
    </joint>

    <!--
      PSM_tool_parent_link — boundary link; PSM_instrument attaches here.
      No geometry; same name as Classic and Virtual so PSM_instrument
      macro is generation-agnostic.
    -->
    <link name="${prefix}PSM_tool_parent_link"/>

    <!-- RCM reference frame (kept for any downstream code that uses it) -->
    <link name="${prefix}PSM_RCM_link"/>
    <joint name="${prefix}jrcm" type="fixed">
      <origin xyz="0.10643 0 -0.1731" rpy="3.1416 0 -1.5708"/>
      <parent link="${prefix}PSM_ECM_outer_pitch_top_link"/>
      <child  link="${prefix}PSM_RCM_link"/>
      <axis xyz="0 0 0"/>
    </joint>

  </xacro:macro>

</robot>
