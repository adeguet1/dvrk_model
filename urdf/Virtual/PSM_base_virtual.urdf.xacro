<?xml version="1.0" encoding="utf-8"?>
<robot name="dvrk_psm_virtual" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!--
    Virtual PSM base — simulator variant.

    Replaces the full parallelogram arm with 3 massless, geometry-free
    joints all located at the fixed RCM (trocar) frame in world.
    This is sufficient for simulation when only the instrument matters.

    DOF layout (same joint names as full model — ROS-compatible):
      Joint 1: outer_yaw   (revolute  z, ±π/2)
      Joint 2: outer_pitch (revolute  y, ±π/4)
      Joint 3: insertion   (prismatic z,  0–0.240 m)

    All three links share a small but non-zero inertia so physics
    simulators (Gazebo, Isaac) can integrate without singularities.

    Output: ends at ${prefix}PSM_tool_parent_link — identical to the
    full Classic/Si base so PSM_instrument attaches without modification.

    Parameters:
      prefix    — arm instance prefix, e.g. "PSM1_"
      rcm_xyz   — trocar position in world frame (default: origin)
      rcm_rpy   — trocar orientation in world frame (default: identity)
                  rpy convention: roll-pitch-yaw (radians)
  -->

  <xacro:property name="virtual_mass"  value="0.001"/>  <!-- 1 gram -->
  <xacro:property name="virtual_inertia" value="1e-6"/>  <!-- 1e-6 kg·m² -->

  <xacro:macro name="PSM_base_virtual"
               params="prefix
                       rcm_xyz:='0 0 0'
                       rcm_rpy:='0 0 0'">

    <!-- Fixed anchor: world → RCM frame (trocar location) -->
    <joint name="${prefix}RCM_fixed" type="fixed">
      <parent link="world"/>
      <child  link="${prefix}PSM_RCM_link"/>
      <origin xyz="${rcm_xyz}" rpy="${rcm_rpy}"/>
    </joint>

    <!-- RCM frame link — not a DOF, just a named coordinate frame -->
    <link name="${prefix}PSM_RCM_link"/>

    <!-- ── Joint 1: outer_yaw ───────────────────────────────────────────── -->
    <!--   Revolute about z at the RCM. Models the yaw of the PSM arm.      -->
    <joint name="outer_yaw" type="revolute">
      <parent link="${prefix}PSM_RCM_link"/>
      <child  link="${prefix}PSM_RCM_yaw_link"/>
      <axis xyz="0 0 1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <limit lower="-1.5707963" upper="1.5707963"
             effort="50" velocity="1.0"/>
    </joint>

    <link name="${prefix}PSM_RCM_yaw_link">
      <inertial>
        <mass value="${virtual_mass}"/>
        <inertia ixx="${virtual_inertia}" ixy="0" ixz="0"
                                          iyy="${virtual_inertia}" iyz="0"
                                                                    izz="${virtual_inertia}"/>
      </inertial>
    </link>

    <!-- ── Joint 2: outer_pitch ─────────────────────────────────────────── -->
    <!--   Revolute about y at the RCM. Models the pitch of the PSM arm.    -->
    <joint name="outer_pitch" type="revolute">
      <parent link="${prefix}PSM_RCM_yaw_link"/>
      <child  link="${prefix}PSM_RCM_pitch_link"/>
      <axis xyz="0 1 0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <limit lower="-0.7853982" upper="0.7853982"
             effort="50" velocity="1.0"/>
    </joint>

    <link name="${prefix}PSM_RCM_pitch_link">
      <inertial>
        <mass value="${virtual_mass}"/>
        <inertia ixx="${virtual_inertia}" ixy="0" ixz="0"
                                          iyy="${virtual_inertia}" iyz="0"
                                                                    izz="${virtual_inertia}"/>
      </inertial>
    </link>

    <!-- ── Joint 3: insertion ───────────────────────────────────────────── -->
    <!--   Prismatic along z at the RCM. Models insertion depth.            -->
    <!--   PSM_tool_parent_link serves as the insertion child AND the        -->
    <!--   handoff link to PSM_instrument (same name as in Classic/Si base). -->
    <joint name="insertion" type="prismatic">
      <parent link="${prefix}PSM_RCM_pitch_link"/>
      <child  link="${prefix}PSM_tool_parent_link"/>
      <axis xyz="0 0 1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <limit lower="0.0" upper="0.240"
             effort="50" velocity="0.4"/>
    </joint>

    <!--
      PSM_tool_parent_link — identical name to Classic/Si boundary link.
      PSM_instrument attaches here; no change needed for any generation.
    -->
    <link name="${prefix}PSM_tool_parent_link">
      <inertial>
        <mass value="${virtual_mass}"/>
        <inertia ixx="${virtual_inertia}" ixy="0" ixz="0"
                                          iyy="${virtual_inertia}" iyz="0"
                                                                    izz="${virtual_inertia}"/>
      </inertial>
    </link>

  </xacro:macro>

</robot>
